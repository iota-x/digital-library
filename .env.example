# ─── Required ──────────────────────────────────────────────────────────
# App breaks at runtime without these (lib/env.ts throws on first access).
JWT_SECRET=
MONGODB_URI=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
VAPID_SUBJECT=
VAPID_PRIVATE_KEY=

# ─── Optional ──────────────────────────────────────────────────────────
# Email (verification codes / password reset / notifications).
# PREFERRED for a personal app: Gmail SMTP — delivers to ANY recipient with no
# domain to verify. Use a Gmail account + an App Password (Google Account →
# Security → 2-Step Verification → App passwords). When both are set, Gmail is
# used and Resend is ignored. The From address is forced to GMAIL_USER (Gmail
# requirement); EMAIL_FROM's display name is still used.
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Resend (alternative) — needs a verified sending domain to reach arbitrary
# recipients; the onboarding@resend.dev sandbox only delivers to your own
# account email. Unset both Gmail + Resend → email features no-op (dev).
RESEND_API_KEY=
NOTIFY_EMAIL_1=
NOTIFY_EMAIL_2=
EMAIL_FROM="Us <onboarding@resend.dev>"

# Admin dashboard (/admin). Comma-separated list of emails allowed in — the
# logged-in user's email must be on this list. Unset → admin is disabled for
# everyone (fails closed).
ADMIN_EMAILS=

# Spotify embed. Unset → Spotify section hidden/no-op.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# AI personalization (date-night / reconnect ideas + generated quiz packs).
# Unset → those features use the built-in deterministic library (still work).
# Set a key to personalize with Claude. Optionally override the model.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8   # default; e.g. claude-haiku-4-5 for lower cost

# Cross-instance rate limiting. Unset → in-memory fallback (fine for one
# instance / local dev; breaks across serverless instances on Vercel).
# Use a hosted Redis (e.g. Upstash) rediss:// URL in production.
# UPSTASH_REDIS_URL is accepted as a fallback for the Upstash integration.
# Local dev with Docker: redis://localhost:6379
REDIS_URL=

# Scheduled reminder sweep (/api/cron/reminders) for upcoming anniversaries
# and birthdays. Unset → the cron endpoint refuses to run (503). Set a long
# random string and pass it as ?secret=… or an x-cron-secret header from your
# scheduler (Vercel Cron, cron-job.org, GitHub Action, …).
CRON_SECRET=

# Number of daily quiz packs the /api/cron/daily-quiz sweep generates per run
# (replaces the previous day's). Unset → 3.
DAILY_QUIZ_COUNT=

# Per-day weather snapshot on calendar entries (Open-Meteo, no API key).
# Set to your home coordinates. Unset → weather feature is a silent no-op.
WEATHER_LAT=
WEATHER_LON=

# Real-time error alerts. A Discord or Slack incoming-webhook URL — every
# recorded server/client error fires a throttled message here (one per
# route+message per 10 min). Unset → no-op (errors still persist for the admin
# Health view). Works with either provider (we send `content` and `text`).
ERROR_WEBHOOK_URL=

# Cloudflare Turnstile bot-protection on registration. Create a free widget at
# dash.cloudflare.com → Turnstile; paste the Secret Key here and the Site Key
# below. Both unset → the challenge is skipped and signup works as before.
TURNSTILE_SECRET=

# ─── Premium (Razorpay one-time lifetime unlock) ───
# All optional. Unset → the paywall is OFF and every couple is premium, so the
# app runs exactly as before. To switch it on: (1) create a Razorpay account,
# copy the Key ID + Secret from Settings → API Keys; (2) enable "International
# payments" in the dashboard if you want global cards (UPI works by default);
# (3) add a webhook → https://<domain>/api/billing/webhook for the
# `payment.captured` + `order.paid` events, and set its signing secret below;
# (4) set PREMIUM_LAUNCH_AT to your go-live time — couples created before it are
# grandfathered free; everyone after must pay to unlock premium features.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
PREMIUM_LAUNCH_AT=
# Optional overrides (defaults: 49900 paise = ₹499, INR, 100-photo free cap).
PREMIUM_PRICE_PAISE=
PREMIUM_CURRENCY=
FREE_PHOTO_CAP=

# ─── Public (exposed to the browser) ───────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_APP_NAME=us
# Turnstile Site Key (pairs with TURNSTILE_SECRET above).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Canonical site URL for robots.txt / sitemap.xml / Open Graph metadata.
# Unset → defaults to https://wearesocuteomg.vercel.app
NEXT_PUBLIC_SITE_URL=
