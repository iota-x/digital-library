# ─── Required ──────────────────────────────────────────────────────────
# App breaks at runtime without these (lib/env.ts throws on first access).
JWT_SECRET=
MONGODB_URI=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
VAPID_SUBJECT=
VAPID_PRIVATE_KEY=

# ─── Optional ──────────────────────────────────────────────────────────
# Email (password reset / notifications). Unset → those features no-op.
RESEND_API_KEY=
NOTIFY_EMAIL_1=
NOTIFY_EMAIL_2=
EMAIL_FROM="Us <onboarding@resend.dev>"

# Spotify embed. Unset → Spotify section hidden/no-op.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# AI personalization (date-night / reconnect ideas + generated quiz packs).
# Unset → those features use the built-in deterministic library (still work).
# Set a key to personalize with Claude. Optionally override the model.
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8   # default; e.g. claude-haiku-4-5 for lower cost

# Cross-instance rate limiting. Unset → in-memory fallback (fine for one
# instance / local dev; breaks across serverless instances on Vercel).
# Use a hosted Redis (e.g. Upstash) rediss:// URL in production.
# UPSTASH_REDIS_URL is accepted as a fallback for the Upstash integration.
# Local dev with Docker: redis://localhost:6379
REDIS_URL=

# Scheduled reminder sweep (/api/cron/reminders) for upcoming anniversaries
# and birthdays. Unset → the cron endpoint refuses to run (503). Set a long
# random string and pass it as ?secret=… or an x-cron-secret header from your
# scheduler (Vercel Cron, cron-job.org, GitHub Action, …).
CRON_SECRET=

# Per-day weather snapshot on calendar entries (Open-Meteo, no API key).
# Set to your home coordinates. Unset → weather feature is a silent no-op.
WEATHER_LAT=
WEATHER_LON=

# ─── Public (exposed to the browser) ───────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_APP_NAME=us
